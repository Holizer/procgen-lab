[node name="MapWidthInChunks" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer" parent_id_path=PackedInt32Array(1391092548, 1407372978) index="0" unique_id=1182190479 instance=ExtResource("3_q7my4")]
unique_name_in_owner = true
layout_mode = 2
LabelText = "Map Width In Chunks"
LabelTooltip = "[color=#f2be32][b]Map Width[/b][/color]
[color=#8e6e53][i]Unit: Chunks | Range: 4 - 32 Chunks[/i][/color]

[b]Effect:[/b] Sets the horizontal map size in large puzzle chunks (Macro Cells).
(e.g., at 15 tiles per chunk, a width of 10 chunks creates a grid 150 tiles wide).

[b]Visual Result:[/b] 
[color=#5cb85c]Larger:[/color] Broadens the map horizontally, allowing for many more connected macro-territories.
[color=#d9534f]Smaller:[/color] Narrows the world, limiting the puzzle area to a tight, compact layout."

[node name="MapHeightInChunks" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer" parent_id_path=PackedInt32Array(1391092548, 1407372978) index="1" unique_id=1210564527 instance=ExtResource("3_q7my4")]
unique_name_in_owner = true
layout_mode = 2
LabelText = "Map Height In Chunks"
LabelTooltip = "[color=#f2be32][b]Map Height[/b][/color]
[color=#8e6e53][i]Unit: Chunks | Range: 4 - 32 Chunks[/i][/color]

[b]Effect:[/b] Sets the vertical map size in large puzzle chunks (Macro Cells).
(e.g., at 15 tiles per chunk, a height of 10 chunks creates a grid 150 tiles tall).

[b]Visual Result:[/b] 
[color=#5cb85c]Larger:[/color] Extends the world vertically, giving the WFC solver room to build tall layouts.
[color=#d9534f]Smaller:[/color] Shortens the map boundaries, making the level compact."

[node name="UseBspTopology" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer" parent_id_path=PackedInt32Array(1391092548, 1407372978) index="2" unique_id=248412759 instance=ExtResource("3_q7my4")]
unique_name_in_owner = true
layout_mode = 2
LabelText = "Use BSP Topology"
LabelTooltip = "[color=#f2be32][b]Use BSP Topology[/b][/color]
[color=#8e6e53][i]Toggle | Boolean[/i][/color]

[b]Effect:[/b] Constrains the WFC solver using a BSP-generated room graph as a macro-level skeleton.

[b]Visual Result:[/b] Rooms and corridors follow a structured layout. Disable for a fully unconstrained wave collapse."
Type = 1

[node name="ItemContainer2" type="VBoxContainer" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer" parent_id_path=PackedInt32Array(1391092548, 1407372978) index="3" unique_id=1163697196]
visible = false
layout_mode = 2

[node name="MaxDepth" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer/ItemContainer2" unique_id=1259980806 instance=ExtResource("3_q7my4")]
layout_mode = 2
LabelText = "Macro Subdivision Depth"
LabelTooltip = "[color=#f2be32][b]Macro Subdivision Depth[/b][/color]
[color=#8e6e53][i]Unit: Split Levels | Range: 1 - 20[/i][/color]

[b]Effect:[/b] The maximum number of times the global map can be recursively split into smaller macro-zones before the WFC solver starts.

[b]Visual Result:[/b] 

[color=#5cb85c]Higher value:[/color] Divides the map into a complex network of many small, highly detailed macro-blocks.

[color=#d9534f]Lower value:[/color] The map is split into only a few massive blocks, creating simple, large, uniform territories."

[node name="MinSplitSize" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer/ItemContainer2" unique_id=1672422728 instance=ExtResource("3_q7my4")]
layout_mode = 2
LabelText = "Min Macro Split Size"
LabelTooltip = "[color=#f2be32][b]Min Macro Split Size[/b][/color]
[color=#8e6e53][i]Unit: Macro Cells | Range: 1 - 10[/i][/color]

[b]Effect:[/b] Defines the absolute smallest size a subdivided zone can be, measured in macro-cells/blocks. The generator will stop splitting if a zone gets smaller than this.

[b]Visual Result:[/b] 

[color=#5cb85c]Higher value:[/color] Guarantees that all generated macro-zones remain large and spacious.

[color=#d9534f]Lower value:[/color] Allows zones to shrink down to individual tiny blocks, creating highly fractured layouts."

[node name="AspectRatioThreshold" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer/ItemContainer2" unique_id=145925133 instance=ExtResource("3_q7my4")]
layout_mode = 2
LabelText = "Macro Elongation Limit"
LabelTooltip = "[color=#f2be32][b]Macro Elongation Limit[/b][/color]
[color=#8e6e53][i]Unit: Ratio | Range: 1.0 - 3.0[/i][/color]

[b]Effect:[/b] Limits how stretched a macro-zone can be. If a zone’s length exceeds its width by this factor, it forces a split to prevent extremely narrow rooms.

[b]Visual Result:[/b]
 
[color=#5cb85c]Higher value:[/color] Allows the generation of long, narrow, corridor-like macro-regions.

[color=#d9534f]Close to 1.0:[/color] Forces all macro-zones to remain strictly square, blocky, and symmetrical."

[node name="UseRandomSeed" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer" parent_id_path=PackedInt32Array(1391092548, 1407372978) index="4" unique_id=2136915381 instance=ExtResource("3_q7my4")]
unique_name_in_owner = true
layout_mode = 2
LabelText = "Use Random Seed"
LabelTooltip = "[color=#f2be32][b]Use Random Seed[/b][/color]
[color=#8e6e53][i]Toggle | Boolean[/i][/color]

[b]Effect:[/b] Automatically generates a completely new seed for each run.

[b]Visual Result:[/b] Every single click of the \"Generate\" button will produce a brand new, unique island layout."
Type = 1

[node name="Seed" parent="SettingsAnchor/SettingsPanel/MarginContainer/VBoxContainer/ScrollContainer/ItemContainer" parent_id_path=PackedInt32Array(1391092548, 1407372978) index="5" unique_id=1421268399 instance=ExtResource("3_q7my4")]
unique_name_in_owner = true
layout_mode = 2
LabelText = "Manual Seed"
LabelTooltip = "[color=#f2be32][b]Manual Seed[/b][/color]
[color=#8e6e53][i]Integer Value[/i][/color]

[b]Effect:[/b] Allows you to input a specific numerical key to build the map.

[b]Visual Result:[/b] Using the exact same seed value will always reproduce the identical world layout. Perfect for sharing maps with others!"

